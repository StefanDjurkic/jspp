// Control flow — if/else, for, while, braceless if
function abs(n) {
    if (n < 0) return -n;
    return n;
}

print("abs(-7):", abs(-7));
print("abs(3):", abs(3));

// if/else chain
function classify(n) {
    if (n > 0) {
        return "positive";
    } else if (n < 0) {
        return "negative";
    } else {
        return "zero";
    }
}

print(classify(5));
print(classify(-2));
print(classify(0));

// for loop
let sum = 0;
for (let i = 1; i <= 10; i = i + 1) {
    sum = sum + i;
}
print("sum 1..10:", sum);

// while loop
let count = 0;
let val = 1;
while (val < 100) {
    val = val * 2;
    count = count + 1;
}
print("doublings:", count);
print("val:", val);
