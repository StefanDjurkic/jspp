// Array methods tests
let arr = [3, 1, 4, 1, 5, 9];

// map
let doubled = arr.map((x) => x * 2);
print("map:", doubled.join(","));

// filter
let big = arr.filter((x) => x > 3);
print("filter:", big.join(","));

// reduce
let sum = arr.reduce((acc, x) => acc + x, 0);
print("reduce:", sum);

// find / findIndex
print("find:", arr.find((x) => x > 4));
print("findIndex:", arr.findIndex((x) => x > 4));

// every / some
print("every>0:", arr.every((x) => x > 0));
print("some>8:", arr.some((x) => x > 8));

// forEach
let count = 0;
arr.forEach((x) => { count = count + 1; });
print("forEach:", count);

// slice
print("slice:", arr.slice(1, 3).join(","));

// indexOf / lastIndexOf / includes
print("indexOf:", arr.indexOf(1));
print("lastIndexOf:", arr.lastIndexOf(1));
print("includes:", arr.includes(9));

// join
print("join:", arr.join("-"));

// concat
let merged = [1, 2].concat([3, 4]);
print("concat:", merged.join(","));

// reverse (mutates)
let rev = [1, 2, 3];
rev.reverse();
print("reverse:", rev.join(","));

// sort
let unsorted = [5, 2, 8, 1, 9];
unsorted.sort((a, b) => a - b);
print("sort:", unsorted.join(","));

// flat
let nested = [[1, 2], [3, 4]];
print("flat:", nested.flat().join(","));

// shift / unshift
let q = [1, 2, 3];
let first = q.shift();
print("shift:", first, q.join(","));
q.unshift(0);
print("unshift:", q.join(","));

// keys / values
print("keys:", [10, 20, 30].keys().join(","));
